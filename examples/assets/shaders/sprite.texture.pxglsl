#version 330 core

#include "sprite.uniforms.pxglsl"

in vec4 position;
in vec2 tex;
in vec4 color;
out vec4 pixel_color;

void main(  ) {
	vec4 outputcolor = texture( Texture0, tex.xy );
	outputcolor.a = color.a;
	if ( any( outputcolor.rgb ) ) {
		outputcolor.rgb *= color.rgb;
	}
	else {
		outputcolor.rgb = color.rgb;
	}

	pixel_color = outputcolor;
}
