+/// @cond undocumented
+namespace __embed
+{
+
+  enum __builtin_embed_status
+    {
+      __file_not_found = 0,
+      __file_found = 1,
+      __file_found_no_depends = 2,
+      __file_found_empty = 3,
+    };
+
+  inline constexpr unsigned int __quoted_search_distance = 0b101;
+  inline constexpr unsigned int __where_distance	 = 0b010;
+
+#define _GLIBCXX_EMBED_FAIL(...)		\
+  do						\
+    {						\
+      __glibcxx_assert(false && __VA_ARGS__);   \
+      __builtin_abort();			\
+    } while(false)
+
+#if defined(__cpp_constexpr_exceptions) && defined(__cpp_exceptions)
+#define _GLIBCXX_EMBED_FAIL_WITH(_TY, _MSG, _LOC) throw _TY(_MSG, _LOC)
+#else
+#define _GLIBCXX_EMBED_FAIL_WITH(_TY, _MSG, _LOC) _GLIBCXX_EMBED_FAIL(_MSG)
+#endif
+  // generic implementation to save on copy-paste nonsense
+  // and not come up with clever constraints for the `__resource`
+  // type.
+  template<typename _By, size_t _Ex, typename _Sv>
+    [[nodiscard]]
+    consteval span<const _By, _Ex>
+    __embed(const _Sv& __resource, size_t __offset,
+	    [[maybe_unused]] const optional<size_t>& __limit)
+    noexcept
+    {
+      int __status = -1;
+      _By const* __ptr = nullptr;
+      size_t __size = 0;
+      if constexpr (_Ex != dynamic_extent)
+	{
+	  __ptr = __builtin_std_embed(__quoted_search_distance, __status,
+				      __size, __ptr,
+				      __resource.size(), __resource.data(),
+				      __offset, _Ex);
+	}
+      else
+	{
+	  __ptr = __limit
+	    ? __builtin_std_embed(__quoted_search_distance, __status,
+				  __size, __ptr,
+				  __resource.size(), __resource.data(),
+				  __offset, *__limit)
+	    : __builtin_std_embed(__quoted_search_distance, __status,
+				  __size, __ptr,
+				  __resource.size(), __resource.data(),
+				  __offset);
+	}
+      if (__status == __file_not_found)
+	{
+#if __has_builtin(__builtin_source_location_at)
+	  auto __where = __builtin_source_location_at(__where_distance);
+	  [[maybe_unused]] auto __loc = source_location::current(__where);
+#else
+	  [[maybe_unused]] auto __loc = source_location::current();
+#endif
+	  _GLIBCXX_EMBED_FAIL_WITH(dependency_error,
+			   "file not covered by a '#depend' directive", __loc);
+	}
+      if (__status == __file_found_no_depends)
+	{
+#if __has_builtin(__builtin_source_location_at)
+	  auto __where = __builtin_source_location_at(__where_distance);
+	  [[maybe_unused]] auto __loc = source_location::current(__where);
+#else
+	  [[maybe_unused]] auto __loc = source_location::current();
+#endif
+	  _GLIBCXX_EMBED_FAIL_WITH(dependency_error,
+			   "file not covered by a '#depend' directive", __loc);
+	}
+      if constexpr (_Ex != dynamic_extent)
+	{
+	  if (_Ex > __size)
+	    {
+	      _GLIBCXX_EMBED_FAIL("extent is larger than the file's size");
+	    }
+	  __size = _Ex;
+	}
+      if (__status == __file_found_empty)
+	{
+	  return span<const _By, _Ex>();
+	}
+      return span<const _By, _Ex>(__ptr, __size);
+    }
+
+#undef _GLIBCXX_EMBED_FAIL
+#undef _GLIBCXX_EMBED_FAIL_WITH
+
+}
+/// @endcond
+
+
