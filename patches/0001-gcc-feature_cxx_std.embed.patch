+	 can handle UTF-8.  */
+      const size_t __what_size = _M_what->size();
+      _M_u8what.resize(__what_size);
+      string& __wh = *_M_what;
+      for (size_t __idx = 0; __idx < __what_size; ++__idx)
+	_M_u8what[__idx] = __wh[__idx];
+    }
