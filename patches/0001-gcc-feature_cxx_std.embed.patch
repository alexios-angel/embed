+  /// @brief An error thrown when a file is not found at compile time, particular with `std::embed`.
+  class file_not_found_error : public std::exception
+  {
+  private:
+    optional<string> _M_what;
+    u8string _M_u8what;
+    source_location _M_where;
+
+  public:
+    consteval
+    file_not_found_error(u8string_view __u8what,
+			 source_location __where = source_location::current())
+    noexcept
+    : _M_what(), _M_u8what(__u8what), _M_where(std::move(__where))
+    {
+      /* FIXME: we are just assuming the ordinary literal encoding
+	 can handle UTF-8.  */
+      const size_t __u8what_size = _M_u8what.size();
+      _M_what.emplace(__u8what_size, '\0');
+      string& __wh = *_M_what;
+      for (size_t __idx = 0; __idx < __u8what_size; ++__idx)
+       __wh[__idx] = static_cast<char>(_M_u8what[__idx]);
+    }
+
+    consteval
+    file_not_found_error(string_view __what,
+			 source_location __where = source_location::current())
+    noexcept
+    : _M_what(__what), _M_u8what(), _M_where(std::move(__where))
+    {
+      /* FIXME: we are just assuming the ordinary literal encoding
+	 can handle UTF-8.  */
+      const size_t __what_size = _M_what->size();
+      _M_u8what.resize(__what_size);
+      string& __wh = *_M_what;
+      for (size_t __idx = 0; __idx < __what_size; ++__idx)
+	_M_u8what[__idx] = __wh[__idx];
+    }
+
+    file_not_found_error(const file_not_found_error&) = default;
+    file_not_found_error(file_not_found_error&&)      = default;
+
+    file_not_found_error& operator=(const file_not_found_error&) = default;
+    file_not_found_error& operator=(file_not_found_error&&)      = default;
+
+    constexpr const char*
+    what() const noexcept override
+    { return _M_what ? _M_what->c_str() : ""; }
+
+    consteval u8string_view
+    u8what() const noexcept
+    { return _M_u8what; }
+
+    consteval source_location
+    where() const noexcept
+    { return _M_where; }
+  };
+
+  /// @brief An error thrown when a file is found, but not properly `#depend`-ed on for use with with `std::embed`.
+  class dependency_error : public std::exception
+  {
+  private:
+    optional<string> _M_what;
+    u8string _M_u8what;
+    source_location _M_where;
+
+  public:
